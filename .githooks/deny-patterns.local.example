# Machine-local deny patterns - NOT committed to git.
# Copy this file to deny-patterns.local and fill in work-specific terms.
#
#   cp .githooks/deny-patterns.local.example .githooks/deny-patterns.local
#
# One ripgrep regex per line. Blank lines and lines starting with # are ignored.
# Matched against git diff --cached (staged changes only).

# ─── Company / org names ──────────────────────────────────────────────────────
# YourCompany
# your-org-name

# ─── Internal service names ───────────────────────────────────────────────────
# internal-service-name
# another-internal-api

# ─── Internal domain patterns ─────────────────────────────────────────────────
# \.yourcompany\.com
# \.internal\.yourcompany

# ─── Internal gem / package names ────────────────────────────────────────────
# gem\s+['"]your-internal-gem
# require\s+['"]your-internal-lib

# ─── Slack / Jira / internal tool references ─────────────────────────────────
# your-jira-project-key
# your-slack-workspace\.slack\.com

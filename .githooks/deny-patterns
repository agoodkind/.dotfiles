# Deny patterns for pre-commit hook.
# One ripgrep regex per line. Blank lines and lines starting with # are ignored.
# These patterns are matched against the staged diff (git diff --cached).
# Use: git commit --no-verify to bypass for confirmed false positives.

# ─── Ruby / Rails ─────────────────────────────────────────────────────────────

# Core Rails classes
ActiveRecord
ApplicationRecord
ApplicationController
Rails\.application
Rails\.env

# ActiveRecord associations and validations
has_many\s
belongs_to\s
has_one\s
has_and_belongs_to_many\s
validates\s
before_action\s
after_action\s
before_save\s
after_commit\s

# Rails file/require patterns
require\s+['"]rails
gem\s+['"]
bundle exec

# Rails template/render patterns
render\s+:?partial
\.html\.erb
\.json\.jbuilder

# Rails environment files
production\.rb
staging\.rb
database\.yml

# ─── Go ───────────────────────────────────────────────────────────────────────

# Go patterns removed: dots/ is a real Go module living in this repo, so
# scanning every diff for ^package/^func/fmt.Print*/^type ... struct produced
# false positives on legitimate dots/ source and on the go-makefile lint
# baseline files (which echo analyzer messages such as "do not use fmt.Println").
# Ruby and Rails markers stay because no Rails code is meant to live here.

# ─── General proprietary indicators ──────────────────────────────────────────

# Internal/corporate domain patterns
\.internal$
\.corp$
corp\.
\.internal\.

#!/usr/bin/env bash

set -euo pipefail

DOTDOTFILES="${DOTDOTFILES:-$HOME/.dotfiles}"

run_refresh() {
    source "$DOTDOTFILES/dots/bootstrap-go.sh"
    run_dots_go_command dispatch prefer-cache-rebuild zwc-recompile
}

if [[ "${1:-}" == "--async" ]]; then
    run_refresh >/dev/null 2>&1 &
    exit 0
fi

run_refresh

#!/usr/bin/env python3
"""Sync .cursor/rules MDC files to Cursor's cloud User Rules via API.
"""

import os
import sqlite3
import subprocess
import sys
import concurrent.futures
from pathlib import Path

# Cursor paths
CURSOR_DB = Path.home() / "Library/Application Support/Cursor/User/globalStorage/state.vscdb"
RULES_DIR = Path(os.environ.get("CURSOR_RULES_DIR", Path.home() / ".dotfiles/.cursor/rules"))
API_BASE = "https://api2.cursor.sh/aiserver.v1.AiService"
WORKSPACE_URL = os.environ.get("DEFAULT_RULE_URL", "https://github.com/agoodkind/.dotfiles")

# CLI options
QUIET = "-q" in sys.argv
INTERACTIVE = sys.stdout.isatty()


# =============================================================================
# Minimal protobuf encoding/decoding (no external dependencies)
# =============================================================================

def encode_varint(value: int) -> bytes:
    result: list[int] = []
    while value > 0x7F:
        result.append((value & 0x7F) | 0x80)
        value >>= 7
    result.append(value & 0x7F)
    return bytes(result)


def read_varint(data: bytes, pos: int) -> tuple[int, int]:
    result = 0
    shift = 0
    while pos < len(data):
        b = data[pos]
        pos += 1
        result |= (b & 0x7F) << shift
        if not (b & 0x80):
            break
        shift += 7
    return result, pos


def encode_bytes_field(field_num: int, value: str | bytes) -> bytes:
    if isinstance(value, str):
        value = value.encode("utf-8")
    tag = (field_num << 3) | 2
    return bytes([tag]) + encode_varint(len(value)) + value


def parse_field(data: bytes, pos: int) -> tuple[int | None, int | None, int | bytes | None, int]:
    if pos >= len(data):
        return None, None, None, pos

    tag, pos = read_varint(data, pos)
    field_num = tag >> 3
    wire_type = tag & 0x07

    if wire_type == 0:
        val, pos = read_varint(data, pos)
        return field_num, wire_type, val, pos
    elif wire_type == 2:
        length, pos = read_varint(data, pos)
        val = data[pos:pos + length]
        return field_num, wire_type, val, pos + length
    else:
        return None, None, None, len(data)


def parse_message(data: bytes) -> dict[int, bytes | int | list[bytes | int]]:
    fields: dict[int, bytes | int | list[bytes | int]] = {}
    pos = 0
    while pos < len(data):
        field_num, wire_type, val, pos = parse_field(data, pos)
        if field_num is None or val is None:
            break
        if field_num in fields:
            existing = fields[field_num]
            if not isinstance(existing, list):
                fields[field_num] = [existing]
            fields[field_num] = [*fields[field_num], val]  # type: ignore[list-item]
        else:
            fields[field_num] = val
    return fields


# =============================================================================
# Logging
# =============================================================================

def log(msg: str) -> None:
    if not QUIET:
        print(msg)


def log_verbose(msg: str) -> None:
    if not QUIET:
        print(f"    {msg}")


def get_auth_token() -> str:
    conn = sqlite3.connect(CURSOR_DB)
    cursor = conn.execute(
        "SELECT value FROM ItemTable WHERE key = 'cursorAuth/accessToken'"
    )
    token: str = cursor.fetchone()[0].strip('"')
    conn.close()
    return token


def api_call(token: str, endpoint: str, payload: bytes) -> bytes:
    result = subprocess.run(
        [
            "curl", "-s", "-X", "POST",
            f"{API_BASE}/{endpoint}",
            "-H", f"authorization: Bearer {token}",
            "-H", "content-type: application/proto",
            "-H", "connect-protocol-version: 1",
            "--data-binary", "@-",
        ],
        input=payload,
        capture_output=True,
    )
    return result.stdout


def api_call_with_status(token: str, endpoint: str, payload: bytes) -> tuple[int, str]:
    result = subprocess.run(
        [
            "curl", "-s", "-w", "%{http_code}", "-X", "POST",
            f"{API_BASE}/{endpoint}",
            "-H", f"authorization: Bearer {token}",
            "-H", "content-type: application/proto",
            "-H", "connect-protocol-version: 1",
            "--data-binary", "@-",
        ],
        input=payload,
        capture_output=True,
    )
    output = result.stdout.decode("utf-8", errors="ignore")
    http_code = int(output[-3:]) if len(output) >= 3 else 0
    body = output[:-3] if len(output) >= 3 else output
    return http_code, body


def decode_bytes(value: bytes | str | None, default: str = "") -> str:
    if isinstance(value, bytes):
        return value.decode("utf-8")
    return value if value is not None else default


def parse_mdc(content: str) -> str:
    """Strip YAML frontmatter from an MDC file and return the body."""
    body = content
    if body.startswith("---"):
        end = body.find("\n---", 3)
        if end != -1:
            body = body[end + 4:].lstrip("\n")
    return body.strip()


def list_rules(token: str) -> list[dict[str, str]]:
    response = api_call(token, "KnowledgeBaseList", b"")
    if not response:
        return []

    decoded = parse_message(response)
    raw_rules = decoded.get(2, [])

    if isinstance(raw_rules, bytes):
        raw_rules = [raw_rules]

    rules: list[dict[str, str]] = []
    for entry_bytes in raw_rules:
        if not isinstance(entry_bytes, bytes):
            continue
        entry = parse_message(entry_bytes)
        rule = {
            "id": decode_bytes(entry.get(1)),  # type: ignore[arg-type]
            "content": decode_bytes(entry.get(2)),  # type: ignore[arg-type]
            "title": decode_bytes(entry.get(3)),  # type: ignore[arg-type]
            "timestamp": decode_bytes(entry.get(4)),  # type: ignore[arg-type]
        }
        if rule["id"]:
            rules.append(rule)
    return rules


def list_rule_ids(token: str) -> list[str]:
    return [r["id"] for r in list_rules(token) if r.get("id")]


def get_rule_count(token: str) -> int:
    return len(list_rule_ids(token))


def remove_rule(token: str, rule_id: str) -> bytes:
    payload = encode_bytes_field(1, rule_id)
    return api_call(token, "KnowledgeBaseRemove", payload)


def add_rule(token: str, title: str, content: str) -> tuple[bool, str]:
    payload = b""
    payload += encode_bytes_field(1, content)
    payload += encode_bytes_field(2, title)
    payload += encode_bytes_field(3, WORKSPACE_URL)

    http_code, body = api_call_with_status(token, "KnowledgeBaseAdd", payload)
    return 200 <= http_code < 300, body


def delete_all_rules(token: str) -> int:
    rule_ids = list_rule_ids(token)

    if not rule_ids:
        log("  ℹ️  No existing cloud rules found")
        return 0

    total = len(rule_ids)
    log(f"  🗑️  Removing {total} existing rule(s) in parallel...")

    if QUIET:
        with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:
            list(executor.map(lambda rid: remove_rule(token, rid), rule_ids))
    elif INTERACTIVE:
        completed = 0
        bar_width = 40
        with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:
            futures = {executor.submit(remove_rule, token, rid): rid for rid in rule_ids}
            for _ in concurrent.futures.as_completed(futures):
                completed += 1
                pct = completed * 100 // total
                filled = completed * bar_width // total
                bar = "█" * filled + "░" * (bar_width - filled)
                print(f"\r    [{bar}] {completed}/{total} ({pct}%)", end="", flush=True)
        print()
    else:
        for i, rule_id in enumerate(rule_ids, 1):
            remove_rule(token, rule_id)
            log(f"    Deleted rule ID: {rule_id} ({i}/{total})")

    remaining = get_rule_count(token)
    if remaining > 0:
        log(f"  ⚠️  {remaining} rule(s) still present after deletion — API may have rejected some removes")
    else:
        log(f"  ✅ Removed {total} cloud rule(s)")
    return total


def sync_rules() -> None:
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    log("☁️  Cursor Cloud Rules Sync")
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

    if not CURSOR_DB.exists():
        log(f"❌ Cursor database not found: {CURSOR_DB}")
        log("   Make sure Cursor is installed and you're logged in.")
        sys.exit(1)

    if not RULES_DIR.exists():
        log(f"❌ Rules directory not found: {RULES_DIR}")
        sys.exit(1)

    log("")
    log(f"📂 Rules directory: {RULES_DIR}")
    log(f"🔗 API endpoint: {API_BASE}")
    log("")

    log("🔐 Authenticating...")
    token = get_auth_token()

    if not token:
        log("❌ Failed to get auth token. Make sure you're logged into Cursor.")
        sys.exit(1)

    log("  ✅ Authentication successful")
    log("")

    log("🧹 Clearing existing cloud rules...")
    delete_all_rules(token)
    log("")

    rule_files = sorted(RULES_DIR.glob("*.mdc"))
    if not rule_files:
        log(f"⚠️  No .mdc files found in {RULES_DIR}")
        sys.exit(0)

    total_files = len(rule_files)
    log(f"📤 Uploading {total_files} rule(s) to cloud...")
    log("")

    attempted = 0
    succeeded = 0
    failed = 0

    for rule_file in rule_files:
        display_file = str(rule_file)

        if rule_file.is_symlink():
            resolved = rule_file.resolve()
            display_file = f"{rule_file} → {resolved}"
            rule_file = resolved

        if not rule_file.exists():
            continue

        content = parse_mdc(rule_file.read_text())
        title = rule_file.stem
        attempted += 1

        log(f"  📄 [{attempted}/{total_files}] {title}")
        log_verbose(f"Source: {display_file}")
        log_verbose(f"Size: {len(content)} bytes")

        success, response = add_rule(token, title, content)
        if success:
            succeeded += 1
            if response:
                log_verbose(f"Response: {response}")
            log_verbose("Status: ✅ Uploaded")
        else:
            failed += 1
            log(f"    ❌ Failed to upload: {response}")
        log("")

    log("🔍 Verifying cloud rules...")
    cloud_rules = list_rules(token)
    cloud_by_title = {r.get("title", ""): r for r in cloud_rules}

    verified = 0
    verify_failed = 0

    for rule_file in rule_files:
        if rule_file.is_symlink():
            rule_file = rule_file.resolve()
        if not rule_file.exists():
            continue

        expected_content = parse_mdc(rule_file.read_text())
        title = rule_file.stem

        cloud_rule = cloud_by_title.get(title)
        if not cloud_rule:
            log(f"  ❌ Missing: {title}")
            verify_failed += 1
        elif cloud_rule.get("content") != expected_content:
            log(f"  ❌ Content mismatch: {title}")
            log_verbose(
                f"Expected {len(expected_content)} bytes, "
                f"got {len(cloud_rule.get('content', ''))} bytes"
            )
            verify_failed += 1
        else:
            log_verbose(f"✅ {title}: content verified")
            verified += 1

    log("")
    if verify_failed == 0:
        log(f"  ✅ Verified: {verified} rule(s) match local files")
    else:
        log(f"  ⚠️  {verify_failed} rule(s) failed verification")
    log("")

    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    if failed == 0 and verify_failed == 0:
        log(f"✅ Sync complete: {succeeded} rule(s) uploaded and verified")
    elif failed > 0:
        log(
            f"⚠️  Sync completed with errors: {succeeded}/{attempted} succeeded, "
            f"{failed} failed"
        )
    elif verify_failed > 0:
        log(f"⚠️  Sync completed but {verify_failed} rule(s) failed content verification")
    log("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")


if __name__ == "__main__":
    sync_rules()

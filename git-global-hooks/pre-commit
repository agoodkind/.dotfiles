#!/usr/bin/env bash
source "$(dirname "$0")/email-guard.sh"
source "$(dirname "$0")/chain-hook.sh"

identity=$(resolve_allowed_identity)
if [[ -n "$identity" ]]; then
    allowed_email=$(echo "$identity" | head -1)
    allowed_name=$(echo "$identity" | tail -1)
    current_email=$(git config user.email)
    current_name=$(git config user.name)

    if [[ "$current_email" != "$allowed_email" ||
        "$current_name" != "$allowed_name" ]]; then
        echo "error: commit blocked"
        echo "  current: $current_name <$current_email>"
        echo "  allowed: $allowed_name <$allowed_email>"
        echo ""
        echo "Fix:"
        if [[ "$current_email" != "$allowed_email" ]]; then
            echo "  git config user.email $allowed_email"
        fi
        if [[ "$current_name" != "$allowed_name" ]]; then
            echo "  git config user.name \"$allowed_name\""
        fi
        exit 1
    fi
fi

# Collect staged shell files (excluding third-party submodules)
_staged_shell=()
while IFS= read -r _f; do
    case "$_f" in
        lib/zinit/* | lib/zsh-defer/*) ;;
        *.sh | *.bash | *.zsh) _staged_shell+=("$_f") ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#_staged_shell[@]} -gt 0 ]]; then
    # Style check: every [[ ]]/if and (( ))/if must be a full if/then/fi block
    if command -v ast-grep >/dev/null; then
        if ! ast-grep scan "${_staged_shell[@]}"; then
            echo ""
            echo "error: shell lint violations found — fix them before committing."
            echo "hint:  run 'make fix' to auto-fix, then re-stage and commit."
            exit 1
        fi
    fi

    # Format check: shfmt (filter out files with zsh-only syntax it can't parse)
    if command -v shfmt >/dev/null; then
        local _repo_root
        _repo_root="$(git rev-parse --show-toplevel)"
        local _fmt_files
        _fmt_files=$(printf '%s\n' "${_staged_shell[@]}" \
            | "$_repo_root/linting/shfmt-filter.sh")
        if [[ -n "$_fmt_files" ]]; then
            if ! printf '%s\n' "$_fmt_files" | xargs shfmt -i 4 -ci -d; then
                echo ""
                echo "error: shell formatting issues found — fix them before committing."
                echo "hint:  run 'make fmt' to auto-format, then re-stage and commit."
                exit 1
            fi
        fi
    fi
fi

chain_hook pre-commit "$@"

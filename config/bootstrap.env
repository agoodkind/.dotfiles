# Shell-side bootstrap config, sourced by dots/bootstrap-go.sh BEFORE Go exists,
# so it cannot live in the Go-read TOML catalog. Plain shell, sourced under set -u.
#
# Uses the `: "${VAR:=default}"` assign-if-unset idiom so an explicit environment
# value (e.g. the smoke passing DOTS_BUILD_LOCK_WAIT_SECONDS) still wins; a plain
# VAR=default would clobber the caller's override. Every value is also defaulted
# in bootstrap-go.sh, so a missing file is harmless.

# Offline floor for the bootstrap Go version. When online, bootstrap derives the
# version from dots/go.mod, so this only applies if go.dev is unreachable.
: "${DEFAULT_GO_BOOTSTRAP_VERSION:=go1.22.7}"
# macOS 11 cannot run Go newer than this.
: "${GO_DARWIN11_BOOTSTRAP_VERSION:=go1.24.13}"

# Bound the build lock wait so a wedged build cannot pile up blocked logins.
: "${DOTS_BUILD_LOCK_WAIT_SECONDS:=120}"
# Bound the build itself so a hung toolchain step fails instead of hanging.
: "${DOTS_BUILD_TIMEOUT_SECONDS:=600}"
# Bound the Go toolchain download so an unreachable go.dev fails fast.
: "${DOTS_DOWNLOAD_CONNECT_TIMEOUT:=20}"
: "${DOTS_DOWNLOAD_MAX_TIME:=600}"
